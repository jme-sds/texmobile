# .env.example — environment variables for the texmobile Docker Compose stack.
#
# Copy this file to .env:
#   cp .env.example .env
#
# Then reference it from compose.yml by adding to each service:
#   env_file: .env
#
# All variables are shown with their built-in defaults.
# Only override the ones you actually need to change.


# ── Backend ───────────────────────────────────────────────────────────────────

# Path inside the container where LaTeX projects are stored.
# Must match the right-hand side of the backend volume mount in compose.yml.
PROJECTS_DIR=/app/projects

# Keep Python output unbuffered so logs appear in real time in docker logs.
PYTHONUNBUFFERED=1

# Comma-separated list of origins allowed to make cross-origin requests to the
# backend.  In the standard Docker Compose setup the frontend proxies all API
# calls server-side, so this only matters when the backend port is exposed
# directly (e.g. during development).
# Default covers common local dev ports; tighten for production.
CORS_ORIGINS=http://localhost:3000,http://localhost:4444

# Optional shared secret that protects the POST /api/chat/config endpoint.
# When set, callers must supply the value as a Bearer token:
#   Authorization: Bearer <value>
# Leave empty to allow unauthenticated config writes (acceptable on localhost).
CONFIG_SECRET=

# Pre-configure LLM credentials via environment variables.
# When set, these override any values stored in projects/.llm_config.json,
# so you never need to enter them through the Settings UI.
LLM_API_ENDPOINT=
LLM_API_KEY=
LLM_MODEL_NAME=

# Demo mode: when set to "true", the Settings UI shows LLM config as read-only
# and the POST /api/chat/config endpoint returns 403.  All LLM features still
# work normally.  Intended for public-facing demos where you don't want visitors
# changing credentials.  Pair with LLM_API_KEY / LLM_API_ENDPOINT / LLM_MODEL_NAME.
# Note: DEMO_MODE is automatically forced true when MULTI_USER_MODE=true.
DEMO_MODE=false


# ── Multi-user authentication ─────────────────────────────────────────────────

# Set to "true" to enable the login screen and per-user project isolation.
# When "false" (default), the app loads directly with no login — intended for
# personal servers where you are the only user.
MULTI_USER_MODE=false

# Required when MULTI_USER_MODE=true.  Used to sign and verify JWT tokens.
# Generate a secure value with:  openssl rand -hex 32
JWT_SECRET=

# Demo account credentials.  When set alongside MULTI_USER_MODE=true, a demo
# account is created automatically and its credentials are displayed on the
# login screen so visitors can try the app without registering.
# The demo account's projects are reset daily.
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo123


# ── Frontend ──────────────────────────────────────────────────────────────────

# Next.js runtime mode.  Must be "production" for the standalone server output.
NODE_ENV=production

# NOTE: API_URL is NOT listed here because it is a build-time variable.
# next.config.ts reads it during `next build` and bakes the rewrite destination
# into the compiled bundle — it cannot be changed at runtime without rebuilding
# the frontend image.  The image is built with API_URL=http://backend:8000,
# which is the correct value for the standard Docker Compose setup where the
# backend service is named "backend".
#
# If you need a different backend URL, build the frontend image yourself:
#   docker build --build-arg API_URL=http://myhost:8000 -t my-frontend ./frontend
